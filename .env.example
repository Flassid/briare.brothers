# ===========================================
# Briare Brothers - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values

# ===========================================
# Site Configuration
# ===========================================
NEXT_PUBLIC_SITE_URL=https://briarebrothers.com

# ===========================================
# Contact Form / Email Service
# ===========================================
# Choose one email service and configure it:

# Option 1: Resend (recommended)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
CONTACT_EMAIL=contact@briarebrothers.com

# Option 2: SendGrid
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
# SENDGRID_FROM_EMAIL=noreply@briarebrothers.com

# Option 3: SMTP (Nodemailer)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@briarebrothers.com

# ===========================================
# Analytics (Optional)
# ===========================================
# Google Analytics
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Vercel Analytics (auto-enabled on Vercel)
# No configuration needed

# Plausible Analytics
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=briarebrothers.com

# ===========================================
# Error Tracking (Optional)
# ===========================================
# Sentry
# SENTRY_DSN=https://xxxxxxxx@sentry.io/xxxxxx
# SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxx

# ===========================================
# Database (Optional - for future features)
# ===========================================
# PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/briarebrothers

# MongoDB
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/briarebrothers

# ===========================================
# Authentication (Optional - for future features)
# ===========================================
# NextAuth.js
# NEXTAUTH_URL=https://briarebrothers.com
# NEXTAUTH_SECRET=your-secret-key-here

# ===========================================
# CMS (Optional - for blog/content)
# ===========================================
# Contentful
# CONTENTFUL_SPACE_ID=xxxxxxxxxxxx
# CONTENTFUL_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxx

# Sanity
# SANITY_PROJECT_ID=xxxxxxxxxxxx
# SANITY_DATASET=production
# SANITY_API_TOKEN=xxxxxxxxxxxxxxxxxxxx
